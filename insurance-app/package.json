{
  "name": "insurance-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend/*",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently -k -n postgres,gateway,quote,policy,frontend -c yellow,cyan,green,magenta,blue \"npm run dev:db\" \"npm run dev --workspace backend/api-gateway\" \"npm run dev --workspace backend/quote-service\" \"npm run dev --workspace backend/policy-service\" \"npm run dev --workspace frontend\"",
    "dev:db": "docker compose up postgres",
    "dev:db:detached": "docker compose up -d postgres",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.26.1"
  }
}
